# ─── Cluster settings (override defaults) ─────────────────────────────────────
CLUSTER_NAME=talos
CONTROL_COUNT=3
WORKER_COUNT=1

# ─── VM resources ─────────────────────────────────────────────────────────────
CP_CPUS=2
CP_MEMORY=2048
WORKER_CPUS=1
WORKER_MEMORY=1024
DISK_SIZE=10G

# ─── Network ──────────────────────────────────────────────────────────────────
SUBNET=192.168.121
VIP=192.168.121.100

# ─── Talos ────────────────────────────────────────────────────────────────────
INSTALL_DISK=/dev/vda
ALLOW_SCHED_ON_CP=false

# ─── Cilium IP pool (inside your SUBNET, outside DHCP) ───────────────────────
CILIUM_IP_POOL_START=192.168.121.160
CILIUM_IP_POOL_STOP=192.168.121.170
