# ─── Cluster settings (override defaults) ─────────────────────────────────────
CLUSTER_NAME=talos
CONTROL_COUNT=3
WORKER_COUNT=2

# ─── VM resources ─────────────────────────────────────────────────────────────
CP_CPUS=2
CP_MEMORY=4048
WORKER_CPUS=4
WORKER_MEMORY=8024
DISK_SIZE=20G

# ─── Network ──────────────────────────────────────────────────────────────────
SUBNET=192.168.121
VIP=192.168.121.100

# ─── Talos ────────────────────────────────────────────────────────────────────
INSTALL_DISK=/dev/vda
ALLOW_SCHED_ON_CP=false

# ─── Cilium IP pool (inside your SUBNET, outside DHCP) ───────────────────────
CILIUM_IP_POOL_START=192.168.121.160
CILIUM_IP_POOL_STOP=192.168.121.170

# ─── Longhorn (optional) ─────────────────────────────────────────────────────
# Uncomment to add a dedicated disk on each node for Longhorn storage:
LONGHORN_DISK_SIZE=20G

# ─── Timeouts (for full-deploy) ────────────────────────────────────────────────
DEPLOY_TIMEOUT=40m   # Max time for Talos bootstrap + Cilium install
FLUX_TIMEOUT=10m     # Max time for FluxCD bootstrap

# ─── FluxCD (optional — GitOps) ──────────────────────────────────────────────
# GitHub token with repo access (needed for flux bootstrap github):
# Export in your shell before running `make setup-flux`:
#   export GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# Or add to your .env file (gitignored)
